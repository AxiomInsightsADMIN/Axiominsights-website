---
import Layout from '../layouts/Layout.astro';
import ArgusMark from '../components/ArgusMark.astro';

const title = 'Axiom Insights LLC | Data Analytics and Web & Systems Design';
const description = 'A data analytics and systems design firm. Axiom Insights transforms field-derived collection into structured intelligence and delivers the interfaces, dashboards, and tooling that put it into operational use.';
---

<Layout title={title} description={description}>
  <!-- Utility bar -->
  <div class="util-bar">
    <div class="container">
      <span>Axiom Insights LLC</span>
      <span class="util-sep">&middot;</span>
      <span>Data analytics &amp; web systems design</span>
    </div>
  </div>

  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="wordmark" aria-label="Axiom Insights home">
        <ArgusMark size={34} pupil="#0F1216" class="wordmark-argus" />
        <span class="wordmark-mark">AXIOM</span>
        <span class="wordmark-sub">Insights</span>
      </a>
      <nav aria-label="Primary">
        <a href="#what-we-do">What we do</a>
        <a href="#capabilities">Capabilities</a>
        <a href="#proof">Work</a>
        <a href="#company">Company</a>
        <a href="#contact" class="nav-cta">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="container">
        <div class="hero-eyebrow">Data analytics &middot; Web &amp; systems design</div>
        <h1>From raw collection<br />to <span class="gradient-text">decision-ready.</span></h1>
        <p class="lead">
          A data analytics and systems design firm. We transform field-derived collection
          into structured intelligence, then deliver the interfaces, dashboards, and
          tooling that put it into operational use.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="#contact">Get in touch</a>
          <a class="btn btn-ghost" href="#what-we-do">What we do <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </section>

    <hr class="wisp-divider" />

    <!-- What we do -->
    <section id="what-we-do" class="section">
      <div class="container section-grid">
        <div class="section-head">
          <h4>What we do</h4>
          <h2>The analytics and delivery layer for field-derived data.</h2>
        </div>
        <div class="section-body">
          <p>
            Axiom Insights engineers the analytics and delivery layer for organizations
            operating on field-derived data. We ingest raw, fragmented, and operator-collected
            inputs such as wireless signal capture, geolocation, imagery, video, and ambient
            environmental data, then normalize them into a single synchronized, structured
            record suited to analysis.
          </p>
          <p>
            That pipeline is paired with web-based dashboards, reports, and client-facing
            interfaces, engineered so analytic output is operational at the point of
            delivery rather than deferred to post-processing.
          </p>
        </div>
      </div>
    </section>

    <!-- Capabilities -->
    <section id="capabilities" class="section section-alt">
      <div class="container">
        <div class="section-head centered">
          <h4>Capabilities</h4>
          <h2>Three disciplines, one pipeline.</h2>
        </div>
        <div class="cards">
          <article class="card">
            <div class="card-bar" aria-hidden="true"></div>
            <div class="card-number">01</div>
            <h3>Data analytics and insights</h3>
            <p>
              Ingestion, normalization, and analysis of field-derived data. We structure
              fragmented input against consistent schemas and produce analytics suited to
              decision-grade use.
            </p>
          </article>
          <article class="card">
            <div class="card-bar" aria-hidden="true"></div>
            <div class="card-number">02</div>
            <h3>Web and systems design</h3>
            <p>
              Custom dashboards, client-facing interfaces, and data-delivery systems engineered
              to match operational workflow. Clear, fast, and built to surface the data
              rather than decorate it.
            </p>
          </article>
          <article class="card">
            <div class="card-bar" aria-hidden="true"></div>
            <div class="card-number">03</div>
            <h3>Integrated signal and sensor capture</h3>
            <p>
              We design the tools and systems that fuse wireless signal capture, geolocation,
              imagery, video, and ambient environmental data into a single synchronized,
              structured record, ensuring the inputs to our analytics pipeline remain
              consistent across operators, locations, and collection cycles.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Focus Areas -->
    <section class="section">
      <div class="container section-grid">
        <div class="section-head">
          <h4>What we work on</h4>
          <h2>Clients whose decisions depend on field-derived data.</h2>
        </div>
        <div class="section-body">
          <p>Current engagement focus areas include:</p>
          <ul class="focus-list">
            <li>Anti-fraud and transnational crime infrastructure mapping</li>
            <li>Critical infrastructure RF baselining and anomaly detection</li>
            <li>Commercial site-security and facility-environment characterization</li>
            <li>Anti-trafficking and humanitarian field-survey support for NGOs and investigators</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Proof section: elevated panel with electric bar -->
    <section id="proof" class="section section-elevated">
      <div class="container section-grid">
        <div class="section-head">
          <h4>Proven in the field</h4>
          <h2>Capability validated through delivery.</h2>
        </div>
        <div class="section-body">
          <p>
            Axiom Insights and its field-operations affiliate have completed two
            area-of-operations survey proofs of concept and delivered production web
            systems and dashboards for internal and client use.
          </p>
          <div class="stat-row">
            <div class="stat">
              <div class="stat-value">2</div>
              <div class="stat-label">Successful proof of concept engagements across Southeast Asia</div>
            </div>
            <div class="stat">
              <div class="stat-value">5</div>
              <div class="stat-label">Production web systems delivered: three sites and two dashboards (operational, client-facing visualization)</div>
            </div>
          </div>
          <p>
            The methodology developed across those engagements forms the operational
            foundation of every current Axiom offering.
          </p>
        </div>
      </div>
    </section>

    <!-- Company -->
    <section id="company" class="section">
      <div class="container section-grid">
        <div class="section-head">
          <h4>Company</h4>
          <h2>Wyoming-based. Built for repeatable, evidence-based work.</h2>
        </div>
        <div class="section-body">
          <p>
            Axiom Insights LLC is a Wyoming-based data analytics and systems design firm.
            We serve commercial security operators, NGOs and investigative organizations,
            infrastructure operators, and other clients who require consistent, structured
            data from the field, along with the analytics and interfaces that render
            it operational.
          </p>
          <p>Headquartered in Sheridan, Wyoming.</p>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section section-alt">
      <div class="container section-grid">
        <div class="section-head">
          <h4>Get in touch</h4>
          <h2>Partnerships, inquiries, and field collaborations.</h2>
        </div>
        <div class="section-body">
          <p>
            Direct inquiries, partnership proposals, and engagement scoping can be routed
            to the contact below. Responses within one business day.
          </p>
          <dl class="contact-list">
            <dt>Email</dt>
            <dd><a href="mailto:sales@axiominsights.org">sales@axiominsights.org</a></dd>
            <dt>Mail</dt>
            <dd>
              Axiom Insights LLC<br />
              30 N Gould St, Ste #41601<br />
              Sheridan, WY 82801
            </dd>
          </dl>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <div class="footer-lockup">
          <ArgusMark size={48} pupil="#07090C" />
          <div class="footer-lockup-text">
            <div class="wordmark-mark">AXIOM</div>
            <div class="wordmark-sub-alt">Insights</div>
          </div>
        </div>
        <p>
          Data analytics and systems design for organizations operating on
          field-derived data.
        </p>
      </div>
      <div class="footer-col">
        <h4>Site</h4>
        <ul>
          <li><a href="#what-we-do">What we do</a></li>
          <li><a href="#capabilities">Capabilities</a></li>
          <li><a href="#proof">Work</a></li>
          <li><a href="#company">Company</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:sales@axiominsights.org">sales@axiominsights.org</a></li>
          <li>Sheridan, Wyoming</li>
        </ul>
      </div>
    </div>
    <div class="footer-base">
      <div class="container">
        <span>Axiom Insights LLC</span>
        <span>&copy; 2026</span>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .container {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding-left: var(--section-padding-x);
    padding-right: var(--section-padding-x);
  }

  /* Utility top bar */
  .util-bar {
    background: var(--color-bg-darker);
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--color-border);
  }
  .util-bar .container {
    padding-top: 0.55rem;
    padding-bottom: 0.55rem;
  }
  .util-sep {
    margin: 0 0.75rem;
    opacity: 0.5;
  }

  /* Header */
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(15, 18, 22, 0.80);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.125rem;
    padding-bottom: 1.125rem;
    gap: 2rem;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text);
    text-decoration: none;
  }
  .wordmark-argus {
    flex-shrink: 0;
    display: block;
    filter: drop-shadow(0 0 12px rgba(77, 198, 255, 0.25));
    transition: filter 200ms ease;
  }
  .wordmark:hover .wordmark-argus {
    filter: drop-shadow(0 0 20px rgba(77, 198, 255, 0.55));
  }
  .wordmark-mark {
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.18em;
    line-height: 1;
    color: var(--color-text);
    text-shadow: 0 0 24px rgba(77, 198, 255, 0.20);
  }
  .wordmark-sub {
    font-size: 0.8125rem;
    color: var(--color-electric);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-left: 0.125rem;
  }
  .wordmark-sub-alt {
    font-size: 0.875rem;
    color: var(--color-electric);
    font-weight: 500;
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
  }
  nav[aria-label="Primary"] {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  nav[aria-label="Primary"] a {
    padding: 0.5rem 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 2px;
    transition: color 120ms ease, background 120ms ease;
  }
  nav[aria-label="Primary"] a:hover {
    color: var(--color-electric);
    background: var(--color-electric-muted);
  }
  nav[aria-label="Primary"] a.nav-cta {
    margin-left: 0.5rem;
    background: var(--color-electric);
    color: var(--color-bg-darker);
    padding: 0.625rem 1.125rem;
    font-weight: 600;
    box-shadow: 0 0 24px var(--color-electric-glow-soft);
  }
  nav[aria-label="Primary"] a.nav-cta:hover {
    background: var(--color-electric-soft);
    box-shadow: 0 0 32px var(--color-electric-glow);
  }

  /* Hero */
  .hero {
    position: relative;
    padding: clamp(5rem, 11vw, 9rem) 0 clamp(4rem, 8vw, 7rem);
    overflow: hidden;
    background: var(--color-bg);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 75% 15%, rgba(77, 198, 255, 0.14), transparent 60%),
      radial-gradient(ellipse 60% 40% at 20% 80%, rgba(77, 198, 255, 0.08), transparent 55%),
      linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    pointer-events: none;
  }
  .hero-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(77, 198, 255, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(77, 198, 255, 0.05) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at 70% 20%, #000 15%, transparent 70%);
  }
  .hero .container {
    position: relative;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-electric);
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--color-border-strong);
    background: var(--color-electric-muted);
    border-radius: 999px;
    margin-bottom: 1.75rem;
    box-shadow: 0 0 20px var(--color-electric-glow-soft) inset;
  }
  .hero h1 {
    max-width: 900px;
  }
  .gradient-text {
    background: linear-gradient(90deg, var(--color-electric) 0%, var(--color-electric-soft) 60%, #B8E8FF 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-shadow: 0 0 40px rgba(77, 198, 255, 0.25);
  }
  .hero .lead {
    font-size: clamp(1.125rem, 1.6vw, 1.3125rem);
    color: var(--color-text-muted);
    max-width: 720px;
    margin-top: 1.5rem;
  }
  .cta-row {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9375rem 1.625rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 2px;
    border: 1px solid transparent;
    transition: background-color 150ms ease, color 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
    letter-spacing: 0.01em;
  }
  .btn-primary {
    background: var(--color-electric);
    color: var(--color-bg-darker);
    border-color: var(--color-electric);
    box-shadow: 0 0 28px var(--color-electric-glow-soft);
  }
  .btn-primary:hover {
    background: var(--color-electric-soft);
    border-color: var(--color-electric-soft);
    box-shadow: 0 0 40px var(--color-electric-glow);
  }
  .btn-ghost {
    background: transparent;
    color: var(--color-electric);
    border-color: var(--color-border-strong);
  }
  .btn-ghost:hover {
    background: var(--color-electric-muted);
    border-color: var(--color-border-hover);
    color: var(--color-electric-soft);
  }

  /* Generic sections */
  .section {
    padding: var(--section-padding-y) 0;
    background: var(--color-bg);
  }
  .section-alt {
    background: var(--color-bg-alt);
  }
  .section-elevated {
    background: var(--color-bg-elevated);
    position: relative;
  }
  .section-elevated::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-electric), transparent);
    opacity: 0.5;
  }
  .section-elevated::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-electric), transparent);
    opacity: 0.5;
  }

  .section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .section-head h4 {
    margin-bottom: 0.75rem;
  }
  .section-head h2 {
    max-width: 18ch;
  }
  .section-head.centered {
    text-align: center;
    margin: 0 auto;
    max-width: 720px;
    margin-bottom: 3rem;
  }
  .section-head.centered h2 {
    max-width: none;
  }
  @media (min-width: 900px) {
    .section-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
      gap: 4rem;
    }
    .section-head {
      position: sticky;
      top: 6rem;
      align-self: start;
    }
  }

  /* Capability cards */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 800px) {
    .cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    padding: 2rem 1.75rem 1.75rem;
    position: relative;
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease, background 200ms ease;
    overflow: hidden;
  }
  .card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-3px);
    box-shadow: 0 24px 60px -28px rgba(77, 198, 255, 0.35);
    background: #222832;
  }
  .card-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 56px;
    background: linear-gradient(180deg, var(--color-electric), transparent);
    box-shadow: 0 0 16px var(--color-electric-glow);
  }
  .card-number {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-electric);
    margin-bottom: 1.5rem;
  }
  .card h3 {
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }
  .card p {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Focus list */
  .focus-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }
  .focus-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 1.0625rem;
    padding-left: 1.5rem;
    position: relative;
    color: var(--color-text);
  }
  .focus-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1.55rem;
    width: 10px;
    height: 1px;
    background: var(--color-electric);
    box-shadow: 0 0 8px var(--color-electric-glow);
  }
  .focus-list li:last-child {
    border-bottom: none;
  }

  /* Stats */
  .stat-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  @media (min-width: 600px) {
    .stat-row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .stat-value {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 800;
    color: var(--color-electric);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.625rem;
    text-shadow: 0 0 32px var(--color-electric-glow);
  }
  .stat-label {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  /* Contact */
  .contact-list {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.75rem 1.75rem;
    align-items: baseline;
  }
  .contact-list dt {
    color: var(--color-electric);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .contact-list dd {
    margin: 0;
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  /* Footer */
  .site-footer {
    background: var(--color-bg-footer);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    position: relative;
  }
  .site-footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-electric), transparent);
    opacity: 0.3;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: clamp(3rem, 5vw, 4.5rem);
    padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  @media (min-width: 800px) {
    .footer-inner {
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3rem;
    }
  }
  .footer-brand .wordmark-mark {
    color: var(--color-text);
    display: block;
  }
  .footer-lockup {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }
  .footer-lockup-text {
    display: flex;
    flex-direction: column;
  }
  .footer-brand p {
    color: var(--color-text-subtle);
    font-size: 0.9375rem;
    max-width: 380px;
  }
  .footer-col h4 {
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer-col a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 120ms ease;
  }
  .footer-col a:hover {
    color: var(--color-electric);
  }
  .footer-base {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }
  .footer-base .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Mobile nav adjustments */
  @media (max-width: 720px) {
    nav[aria-label="Primary"] {
      gap: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    nav[aria-label="Primary"]::-webkit-scrollbar {
      display: none;
    }
    nav[aria-label="Primary"] a {
      padding: 0.5rem 0.625rem;
      font-size: 0.875rem;
      flex-shrink: 0;
    }
    nav[aria-label="Primary"] a.nav-cta {
      padding: 0.5rem 0.875rem;
    }
  }
</style>
